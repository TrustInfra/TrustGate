# TrustGate Environment Configuration
# Copy this file to .env and fill in your values

# Deployer private key (required for live networks)
# PRIVATE_KEY=your_deployer_private_key

# RPC URLs
# SEPOLIA_RPC_URL=https://rpc.sepolia.org
# MAINNET_RPC_URL=https://eth.llamarpc.com
# ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Block explorer API keys
# ETHERSCAN_API_KEY=your_etherscan_or_arcscan_api_key

# Arc Testnet contract addresses (populated after deployment)
# USDC_ADDRESS=0x3600000000000000000000000000000000000000
# EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a

# Gas reporting
REPORT_GAS=false
