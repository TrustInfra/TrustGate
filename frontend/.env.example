# TrustGate frontend environment

# Oracle service base URL (used by /oracle and /agents/live pages)
NEXT_PUBLIC_ORACLE_URL=http://38.49.216.201:3001

# WalletConnect project ID (optional — get one at https://cloud.walletconnect.com)
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Server-only. 0x-prefixed 32-byte hex private key of the hot wallet that
# pays 0.001 USDC per ERC-20 widget query (/api/widget/score/[address]).
# The wallet must hold ERC-20 USDC for transfer value AND Arc native gas
# for tx fees. Without this set, ERC-20 widget queries return 502.
# Never expose with NEXT_PUBLIC_ prefix.
# WIDGET_HOT_WALLET_PRIVATE_KEY=
